  <view class="tutorial-mask {{visible ? 'show' : ''}}" bindtap="closeSheet"></view>
  <view class="tutorial-sheet {{visible ? 'show' : ''}}">
    <view class="tutorial-header">
      <text class="tutorial-title">{{platform === 'xiachufang' ? i18n.tutorial_sheet_title_xcf : i18n.tutorial_sheet_title}}</text>
      <view class="tutorial-close" bindtap="closeSheet">✕</view>
    </view>
    
    <view class="tutorial-content">
      <view class="tutorial-loading" wx:if="{{loading}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">{{i18n.loading}}</text>
      </view>
      
      <view class="tutorial-error" wx:elif="{{error}}">
        <image class="error-icon" src="/images/icons/error.svg" mode="aspectFit"></image>
        <text class="error-text">{{errorMsg}}</text>
        <button class="btn-secondary" bindtap="retryTutorial">{{i18n.res_retake}}</button>
      </view>
      
      <scroll-view scroll-y class="tutorial-list" wx:elif="{{tutorials && tutorials.length > 0}}">
        <view class="tutorial-card" wx:for="{{tutorials}}" wx:key="index" bindtap="openTutorialLink" data-url="{{item.url}}">
          <image class="tutorial-thumb" src="{{item.thumbnail}}" mode="aspectFill"></image>
          <view class="tutorial-info">
            <text class="tutorial-video-title">{{item.title}}</text>
            <view class="tutorial-platform">
              <view class="platform-group">
                <view class="platform-tag {{item.source === 'xiachufang' ? 'xiachufang' : 'bilibili'}}">
                  <text wx:if="{{item.source === 'xiachufang'}}">{{i18n.tutorial_platform_xcf}}</text>
                  <text wx:else>Bilibili</text>
                </view>
                <text class="view-count" wx:if="{{item.viewCountFormatted}}">▶ {{item.viewCountFormatted}}</text>
              </view>
              <text class="tutorial-link-text"><text class="sys-icon icon-link"></text> {{i18n.tutorial_open}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
      
      <view class="tutorial-empty" wx:else>
        <text>{{i18n.tutorial_empty}}</text>
      </view>
    </view>
  </view>