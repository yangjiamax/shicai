/* Tutorial Sheet (Same as MVP) */
.tutorial-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.tutorial-mask.show {
  opacity: 1;
  visibility: visible;
}

.tutorial-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100vw;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.tutorial-sheet.show {
  transform: translateY(0);
}

.tutorial-header {
  padding: 32rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2rpx solid rgba(196, 200, 187, 0.2);
}

.tutorial-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1b1c1c;
}

.tutorial-close {
  padding: 16rpx;
  font-size: 32rpx;
  color: #a0a59a;
}

.tutorial-content {
  flex: 1;
  overflow: hidden;
  position: relative;
  min-height: 400rpx;
}

.tutorial-loading, .tutorial-error, .tutorial-empty {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}

.tutorial-loading .loading-text,
.tutorial-error .error-text,
.tutorial-empty text {
  font-size: 28rpx;
  color: #74796d;
}

.tutorial-error .error-icon {
  width: 80rpx;
  height: 80rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e4e2e1;
  border-top-color: #4b6338;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.btn-secondary {
  background: #f4f6f3;
  color: #4b6338;
  font-size: 28rpx;
  font-weight: 500;
  padding: 16rpx 48rpx;
  border-radius: 100rpx;
  border: none;
  margin-top: 16rpx;
}

.btn-secondary::after {
  display: none;
}

.tutorial-list {
  height: 100%;
  max-height: 60vh;
  padding: 20rpx 40rpx;
  box-sizing: border-box;
}

.tutorial-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid rgba(196, 200, 187, 0.2);
}

.tutorial-thumb {
  width: 200rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #f6f3f2;
  flex-shrink: 0;
}

.tutorial-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.tutorial-video-title {
  font-size: 28rpx;
  color: #1b1c1c;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tutorial-platform {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.platform-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  flex: 1;
}

.platform-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.platform-tag.bilibili {
  background: #fff0f6;
  color: #fb7299;
}

.platform-tag.xiachufang {
  background: #ffeeea;
  color: #dd3915;
}

.view-count {
  font-size: 22rpx;
  color: #a0a59a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tutorial-link-text {
  font-size: 24rpx;
  color: #4b6338;
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 16rpx;
}