page {
  background: #fcf9f8;
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
}

.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

/* Header */
.header {
  text-align: center;
  margin-top: 20rpx;
  margin-bottom: 60rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #4b6338;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: -0.5px;
}

.subtitle {
  font-size: 26rpx;
  color: #74796d;
  font-weight: 500;
}

.main-content {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

/* Hero Camera Card */
.camera-card {
  position: relative;
  width: 100%;
  aspect-ratio: 4/5;
  border-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(75, 99, 56, 0.15);
  transition: all 0.3s ease;
  background: #2a3b1d; /* 深色底色，在图片加载前显示 */
}

.camera-bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.camera-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(75, 99, 56, 0.6) 0%,
    rgba(42, 59, 29, 0.85) 100%
  );
  z-index: 2;
}

.camera-card-hover {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(75, 99, 56, 0.1);
}

.camera-inner {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.camera-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(12px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  margin-bottom: 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.1);
}

.camera-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.9;
}

.camera-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.camera-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.camera-bg-decor {
  position: absolute;
  top: 0;
  right: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at top right, rgba(255,255,255,0.15) 0%, transparent 60%);
  pointer-events: none;
}

/* Album Button */
.album-btn {
  width: 100%;
  height: 120rpx;
  background: #ffffff;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
  border: 2rpx solid rgba(196, 200, 187, 0.2);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  transition: all 0.3s ease;
  position: relative;
}

.album-btn::after {
  border: none;
}

.album-btn-hover {
  background: #f6f3f2;
}

.album-btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.album-icon {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.8;
}

.album-btn text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1b1c1c;
  line-height: 1;
}

.arrow-icon {
  position: absolute;
  right: 40rpx;
  font-size: 32rpx;
  color: #74796d;
  font-family: monospace;
}

/* Loading Overlay */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(252, 249, 248, 0.9);
  backdrop-filter: blur(4px);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  background: #ffffff;
  padding: 60rpx;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(75, 99, 56, 0.1);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 6rpx solid #e4e2e1;
  border-top-color: #4b6338;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 8rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #4b6338;
  font-weight: 600;
}

.loading-hint {
  font-size: 24rpx;
  color: #a0a59a;
  text-align: center;
  max-width: 460rpx;
  line-height: 1.5;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}