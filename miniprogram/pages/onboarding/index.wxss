.onboarding-container {
  min-height: 100vh;
  background-color: #fcf9f8;
  box-sizing: border-box;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  background: #fcf9f8;
}

.nav-back {
  width: 88rpx;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
  transform: rotate(180deg);
}

.header {
  margin-top: 20rpx;
  margin-bottom: 40rpx;
  padding: 0 48rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #74796d;
  line-height: 1.6;
  display: block;
}

.content {
  padding-bottom: 200rpx; /* Leave space for fixed footer */
}

.card-group {
  padding: 0 40rpx;
}

.section {
  margin-bottom: 48rpx;
}

.section-header {
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.section-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

.profile-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
}

.avatar-btn {
  width: 112rpx !important;
  height: 112rpx !important;
  padding: 0 !important;
  margin: 0 !important;
  margin-right: 32rpx !important;
  border-radius: 56rpx !important;
  background: #f0f0f0;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

.nickname-wrapper {
  flex: 1;
  border-bottom: 2rpx solid #f0f0f0;
  padding-bottom: 8rpx;
}

.nickname-input {
  font-size: 32rpx;
  color: #333;
  height: 60rpx;
  min-height: 60rpx;
}

.picker-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  padding: 36rpx 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
}

.picker-text {
  font-size: 32rpx;
  color: #999;
}

.picker-text.selected {
  color: #333;
}

.picker-arrow {
  color: #ccc;
  font-size: 32rpx;
}

.auth-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
  padding: 28rpx 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
  transition: all 0.2s;
}

.auth-card:active {
  transform: scale(0.98);
  background: #f9f9f9;
}

.auth-info {
  display: flex;
  align-items: center;
}

.auth-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: rgba(75, 99, 56, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.auth-icon {
  font-size: 36rpx;
  color: #4b6338;
}

.auth-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.auth-status {
  font-size: 26rpx;
  font-weight: 500;
  color: #fff;
  background-color: #4b6338;
  padding: 12rpx 36rpx;
  border-radius: 40rpx;
}

.auth-status.authed {
  background-color: #f0f0f0;
  color: #999;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx 48rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background: #fcf9f8;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.02);
  z-index: 100;
}

.enter-btn {
  background-color: #4b6338;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 50rpx;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(75, 99, 56, 0.25);
}

.enter-btn::after {
  border: none;
}

.enter-btn:active {
  opacity: 0.9;
  transform: translateY(2rpx);
}