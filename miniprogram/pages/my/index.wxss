.container {
  min-height: 100vh;
  background-color: #fcf9f8;
  padding: 0 16px;
}

.user-card {
  background-color: #ffffff;
  border-radius: 12px;
  padding: 24px;
  margin-top: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2px 8px rgba(27, 28, 28, 0.06);
}

.avatar-section {
  margin-bottom: 16px;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  width: 80px;
  height: 80px;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background-color: #f6f3f2;
}

.nickname-section {
  width: 100%;
  display: flex;
  justify-content: center;
}

.nickname-input {
  width: 160px;
  text-align: center;
  font-size: 18px;
  font-weight: 600;
  color: #1b1c1c;
  padding: 8px 16px;
  background-color: #ffffff;
  border-radius: 4px;
  border: none;
  transition: all 0.2s ease;
}

.nickname-input:focus {
  background-color: #ffffff;
  box-shadow: 0 0 0 1px rgba(196, 200, 187, 0.15);
}

.login-tip {
  margin-top: 12px;
}

.login-tip text {
  font-size: 13px;
  color: #74796d;
}

.history-section {
  margin-top: 24px;
  background-color: #ffffff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(27, 28, 28, 0.06);
}

.section-header {
  padding-bottom: 8px;
  margin-bottom: 16px;
}

.history-tabs {
  display: flex;
  justify-content: space-between;
  gap: 8px;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10px 4px;
  border-radius: 12px;
  font-size: 13px;
  font-weight: 500;
  transition: all 0.3s ease;
  position: relative;
  background-color: #f0f4eb;
  color: #74796d;
}

.tab-item.active {
  background-color: #4b6338;
  color: #ffffff;
  box-shadow: 0 4px 12px rgba(75, 99, 56, 0.2);
  font-weight: 600;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #1b1c1c;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32px 0;
}

.empty-icon {
  font-size: 48px;
  color: #c4c8bb;
  margin-bottom: 12px;
}

.empty-icon-img {
  width: 64px;
  height: 64px;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 15px;
  color: #44483e;
  margin-bottom: 4px;
}

.empty-hint {
  font-size: 13px;
  color: #74796d;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 16px;
  background-color: #ffffff;
  border-radius: 12px;
  border: 1px solid rgba(196, 200, 187, 0.2);
  box-shadow: 0 2px 8px rgba(27, 28, 28, 0.02);
}

.history-item:last-child {
  /* removed border-bottom reset */
}

.history-thumb {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: linear-gradient(135deg, #f0f4eb 0%, #e2e8da 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16px;
  flex-shrink: 0;
  overflow: hidden;
}

.history-thumb-img {
  width: 100%;
  height: 100%;
}

.history-thumb-text {
  font-size: 20px;
  font-weight: 600;
  color: #4b6338;
}

.history-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.history-title-row {
  display: flex;
  align-items: center;
}

.status-tag {
  font-size: 10px;
  color: #4b6338;
  background-color: #f0f4eb;
  padding: 2px 6px;
  border-radius: 4px;
  margin-left: 8px;
  font-weight: 500;
  white-space: nowrap;
}

.history-name {
  font-size: 16px;
  font-weight: 600;
  color: #1b1c1c;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 4px;
}

.history-meta {
  display: flex;
  align-items: center;
  font-size: 13px;
  color: #74796d;
}

.history-recipe {
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.meta-dot {
  margin: 0 6px;
  color: #c4c8bb;
  font-weight: bold;
  flex-shrink: 0;
}

.history-time {
  flex-shrink: 0;
}

.history-arrow-box {
  margin-left: 12px;
  display: flex;
  align-items: center;
}

.history-arrow {
  font-size: 16px;
  color: #c4c8bb;
}

.pagination {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20px;
  padding: 0 8px;
}

.page-btn {
  padding: 8px 16px;
  background-color: #f0f4eb;
  color: #4b6338;
  font-size: 14px;
  font-weight: 500;
  border-radius: 20px;
  transition: all 0.2s ease;
}

.page-btn.disabled {
  background-color: #f6f3f2;
  color: #c4c8bb;
  pointer-events: none;
}

.page-info {
  font-size: 14px;
  color: #74796d;
  font-weight: 500;
}

.settings-section {
  margin-top: 24px;
  background-color: #ffffff;
  border-radius: 12px;
  padding: 0 16px;
  box-shadow: 0 2px 8px rgba(27, 28, 28, 0.06);
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
}

.border-bottom {
  border-bottom: 1px solid rgba(196, 200, 187, 0.2);
}

.settings-left {
  display: flex;
  align-items: center;
}

.settings-icon {
  font-size: 20px;
  margin-right: 12px;
  color: #1b1c1c;
}

.settings-text {
  font-size: 14px;
  color: #1b1c1c;
}

.settings-right {
  display: flex;
  align-items: center;
}

.settings-value {
  font-size: 13px;
  color: #74796d;
  margin-right: 8px;
}

.settings-arrow {
  font-size: 14px;
  color: #c4c8bb;
}

.footer-section {
  margin-top: 24px;
  padding-bottom: 32px;
}

.clear-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 14px;
}

.clear-btn-text {
  font-size: 14px;
  color: #ba1a1a;
}