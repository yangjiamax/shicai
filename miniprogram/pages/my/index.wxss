.container {
  min-height: 100vh;
  background-color: #fcf9f8;
  padding: 0 16px;
}

.user-card {
  background-color: #ffffff;
  border-radius: 12px;
  padding: 24px;
  margin-top: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2px 8px rgba(27, 28, 28, 0.06);
}

.avatar-section {
  margin-bottom: 16px;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  width: 80px;
  height: 80px;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background-color: #f6f3f2;
}

.nickname-section {
  width: 100%;
  display: flex;
  justify-content: center;
}

.nickname-input {
  width: 160px;
  text-align: center;
  font-size: 18px;
  font-weight: 600;
  color: #1b1c1c;
  padding: 8px 16px;
  background-color: #f6f3f2;
  border-radius: 4px;
  border: none;
  transition: all 0.2s ease;
}

.nickname-input:focus {
  background-color: #ffffff;
  box-shadow: 0 0 0 1px rgba(196, 200, 187, 0.15);
}

.login-tip {
  margin-top: 12px;
}

.login-tip text {
  font-size: 13px;
  color: #74796d;
}

.history-section {
  margin-top: 24px;
  background-color: #ffffff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(27, 28, 28, 0.06);
}

.section-header {
  padding-bottom: 8px;
  margin-bottom: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #1b1c1c;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32px 0;
}

.empty-icon-img {
  width: 64px;
  height: 64px;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 15px;
  color: #44483e;
  margin-bottom: 4px;
}

.empty-hint {
  font-size: 13px;
  color: #74796d;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background-color: #f6f3f2;
  border-radius: 12px;
}

.history-item:last-child {
  /* removed border-bottom reset */
}

.history-left {
  flex: 1;
}

.history-name {
  font-size: 16px;
  font-weight: 600;
  color: #1b1c1c;
}

.history-right {
  display: flex;
  align-items: center;
}

.history-recipe-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-right: 8px;
}

.history-recipe {
  font-size: 14px;
  color: #1b1c1c;
  margin-bottom: 2px;
}

.history-time {
  font-size: 12px;
  color: #74796d;
}

.history-arrow {
  font-size: 14px;
  color: #c4c8bb;
}

.footer-section {
  margin-top: 24px;
  padding-bottom: 32px;
}

.clear-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 14px;
}

.clear-btn-text {
  font-size: 14px;
  color: #ba1a1a;
}