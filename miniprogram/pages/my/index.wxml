<view class="container">
  <view class="user-card">
    <view class="avatar-section">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-img" src="{{userInfo.avatar || '/images/icons/user.svg'}}" mode="aspectFill"></image>
      </button>
    </view>
    <view class="nickname-section">
      <input
        class="nickname-input"
        type="nickname"
        placeholder="{{showLoginPrompt ? '点击设置昵称' : '请输入昵称'}}"
        value="{{userInfo.nickname || ''}}"
        bindinput="onNicknameInput"
        bindblur="saveNickname"
      />
    </view>
    <view wx:if="{{showLoginPrompt}}" class="login-tip">
      <text>点击上方头像和昵称即可登录</text>
    </view>
  </view>

  <view class="history-section">
    <view class="section-header">
      <text class="section-title">历史记录</text>
    </view>
    
    <view wx:if="{{isAnonymous}}" class="empty-state">
      <view class="empty-icon">☁️</view>
      <text class="empty-text">请开启云服务以保存历史</text>
      <text class="empty-hint">当前为本地体验模式</text>
    </view>
    <view wx:elif="{{loadError}}" class="empty-state">
      <view class="empty-icon">📶</view>
      <text class="empty-text">网络好像开小差了</text>
      <text class="empty-hint">请检查网络后重试</text>
    </view>
    <view wx:elif="{{histories.length === 0}}" class="empty-state">
      <image class="empty-icon-img" src="/images/icons/empty-vegetable.svg" mode="aspectFit"></image>
      <text class="empty-text">暂无识别记录</text>
      <text class="empty-hint">去拍个食材试试看吧～</text>
    </view>

    <view wx:else class="history-list">
      <view 
        wx:for="{{histories}}" 
        wx:key="_id" 
        class="history-item" 
        bindtap="navigateToHistory" 
        data-index="{{index}}"
      >
        <view class="history-left">
          <text class="history-name">{{item.ingredient_name}}</text>
        </view>
        <view class="history-right">
          <view class="history-recipe-info">
            <text class="history-recipe">{{item.selected_recipe.recipe_name}}</text>
            <text class="history-time">{{item.formattedDate}}</text>
          </view>
          <text class="history-arrow">></text>
        </view>
      </view>
    </view>
  </view>

  <view class="footer-section">
    <view class="clear-btn" bindtap="clearLocalData">
      <text class="clear-btn-text">清除历史记录</text>
    </view>
  </view>
</view>