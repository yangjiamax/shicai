<view class="container">
  <view class="user-card">
    <view class="avatar-section">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-img" src="{{userInfo.avatar || '/images/icons/user.svg'}}" mode="aspectFill"></image>
      </button>
    </view>
    <view class="nickname-section">
      <input
        class="nickname-input"
        type="nickname"
        placeholder="{{showLoginPrompt ? i18n.my_set_nickname : i18n.my_input_nickname}}"
        value="{{userInfo.nickname || ''}}"
        bindinput="onNicknameInput"
        bindblur="saveNickname"
      />
    </view>
    <view wx:if="{{showLoginPrompt}}" class="login-tip">
      <text>{{i18n.my_login_tip}}</text>
    </view>
  </view>

  <view class="history-section">
    <view class="section-header">
      <text class="section-title">{{i18n.my_history_title}}</text>
    </view>
    
    <view wx:if="{{isAnonymous}}" class="empty-state">
      <view class="empty-icon">☁️</view>
      <text class="empty-text">{{i18n.my_cloud_tip}}</text>
      <text class="empty-hint">{{i18n.my_local_mode}}</text>
    </view>
    <view wx:elif="{{loadError}}" class="empty-state">
      <view class="empty-icon">📶</view>
      <text class="empty-text">{{i18n.my_network_error}}</text>
      <text class="empty-hint">{{i18n.my_network_retry}}</text>
    </view>
    <view wx:elif="{{histories.length === 0}}" class="empty-state">
      <image class="empty-icon-img" src="/images/icons/empty-vegetable.svg" mode="aspectFit"></image>
      <text class="empty-text">{{i18n.my_empty_title}}</text>
      <text class="empty-hint">{{i18n.my_empty_desc}}</text>
    </view>

    <view wx:else class="history-list">
      <view 
        wx:for="{{histories}}" 
        wx:key="_id" 
        class="history-item" 
        bindtap="navigateToHistory" 
        data-index="{{index}}"
      >
        <view class="history-thumb">
          <image wx:if="{{item.analysisResult.cloudImagePath || item.analysisResult.imagePath}}" class="history-thumb-img" src="{{item.analysisResult.cloudImagePath || item.analysisResult.imagePath}}" mode="aspectFill"></image>
          <text wx:else class="history-thumb-text">{{item.initial}}</text>
        </view>
        
        <view class="history-info">
          <text class="history-name">{{item.ingredient_name}}</text>
          <view class="history-meta">
            <view class="history-recipe">{{item.selected_recipe.recipe_name}}</view>
            <text class="meta-dot" wx:if="{{item.selected_recipe.recipe_name && item.formattedDate}}">·</text>
            <text class="history-time">{{item.formattedDate}}</text>
          </view>
        </view>

        <view class="history-arrow-box">
          <text class="history-arrow">></text>
        </view>
      </view>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-item" bindtap="switchLanguage">
      <view class="settings-left">
        <text class="settings-icon">🌐</text>
        <text class="settings-text">{{i18n.my_language || '语言 / Language'}}</text>
      </view>
      <text class="settings-arrow">></text>
    </view>
  </view>

  <view class="footer-section">
    <view class="clear-btn" bindtap="clearLocalData">
      <text class="clear-btn-text">{{i18n.my_clear_btn}}</text>
    </view>
  </view>
</view>