@import "../list/index.wxss";

.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  background: #fcf9f8;
}

.recipe-wrapper {
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  padding: 30rpx;
  border: 2rpx solid rgba(255, 77, 79, 0.15); /* Light red border as shown in screenshot */
}

.recipe-wrapper .group-title {
  font-size: 36rpx;
}

.ingredient-tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding-top: 10rpx;
}

.ingredient-tag {
  background: #f4f7f4;
  color: #4a5d4e;
  font-size: 28rpx;
  padding: 12rpx 28rpx;
  border-radius: 100rpx;
  font-weight: 500;
}

.finish-btn-container {
  margin: 60rpx 0 40rpx;
  padding: 0;
}

.btn-primary {
  background: #4b6338;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 40rpx;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(75, 99, 56, 0.2);
  transition: all 0.3s ease;
  width: 100% !important;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(75, 99, 56, 0.1);
}

.btn-secondary {
  background: #f6f3f2;
  color: #4b6338;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 40rpx;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.btn-secondary.btn-icon-only {
  width: 96rpx !important;
  padding: 0 !important;
  flex: 0 0 96rpx !important;
}

.btn-secondary.btn-icon-only image {
  filter: brightness(0) saturate(100%) invert(35%) sepia(21%) saturate(756%) hue-rotate(50deg) brightness(97%) contrast(85%);
  width: 44rpx;
  height: 44rpx;
}

.btn-secondary:active {
  transform: scale(0.98);
  background: #ebe6e4;
}

.btn-primary::after, .btn-secondary::after {
  border: none;
}
