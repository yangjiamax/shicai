@import "../list/index.wxss";

/* Redesign ingredient list as tags for read-only history view */
.ingredient-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 24rpx 20rpx;
  padding-top: 10rpx;
}

.ingredient-item {
  display: inline-flex;
  flex-direction: row;
  background: #f4f6f3;
  padding: 14rpx 32rpx;
  border-radius: 100rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.item-content {
  gap: 0;
  width: auto;
}

.ingredient-info {
  flex: none;
  opacity: 1;
}

.ingredient-name {
  font-size: 28rpx;
  color: #4b6338;
  font-weight: 500;
}

/* Checked/Bought style */
.ingredient-item.checked {
  background: #fafaf9;
  border-color: #e4e2e1;
}

.ingredient-name.checked-text {
  color: #a0a59a;
  text-decoration: line-through;
  font-weight: 400;
}

/* Add Buttons */
.group-header {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  padding: 0 8rpx 16rpx;
  position: relative;
  min-height: 50rpx;
}

.group-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #4b6338;
  padding-right: 60rpx; /* 留出空间给右侧的心形 */
}

.btn-favorite {
  position: absolute;
  right: 0rpx;
  top: -8rpx;
  background: transparent;
  padding: 8rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: transform 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.btn-favorite-hover {
  transform: scale(0.85);
  opacity: 0.8;
}

.icon-heart {
  width: 44rpx;
  height: 44rpx;
}

.search-action-wrapper {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  width: 100%;
}

.search-action-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.search-action-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.group-actions {
  width: 100%;
}

/* Add Entire List Button */
.finish-btn-container {
  margin: 60rpx 0 40rpx;
  padding: 0;
}

.btn-primary {
  background: #4b6338;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 40rpx;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(75, 99, 56, 0.2);
  transition: all 0.3s ease;
  width: 100% !important;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(75, 99, 56, 0.1);
}

.btn-secondary {
  background: #f6f3f2;
  color: #4b6338;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 40rpx;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.btn-secondary.btn-icon-only {
  width: 96rpx !important;
  padding: 0 !important;
  flex: 0 0 96rpx !important;
}

.btn-secondary.btn-icon-only image {
  filter: brightness(0) saturate(100%) invert(35%) sepia(21%) saturate(756%) hue-rotate(50deg) brightness(97%) contrast(85%);
  width: 44rpx;
  height: 44rpx;
}

.btn-secondary:active {
  transform: scale(0.98);
  background: #ebe6e4;
}

.btn-primary::after, .btn-secondary::after {
  border: none;
}
