page {
  background: #fcf9f8;
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  padding-bottom: 200rpx;
}

.container {
  padding: 30rpx;
}

.result-card {
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.ingredient-info {
  padding: 40rpx;
}

.ingredient-header-wrap {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.ingredient-header-left {
  flex: 1;
  padding-right: 20rpx;
}

.ingredient-name-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  gap: 16rpx;
}

.ingredient-header-left .ingredient-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #4b6338;
  letter-spacing: -0.5px;
  display: block;
  text-transform: capitalize;
}

.icon-edit {
  width: 40rpx;
  height: 40rpx;
  padding: 8rpx;
  background: rgba(75, 99, 56, 0.05);
  border-radius: 50%;
}

.ingredient-desc {
  font-size: 28rpx;
  color: #44483e;
  line-height: 1.5;
  display: block;
}

.ingredient-thumb {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
  background-color: #f6f3f2;
}

.ingredient-features {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  background: #fcf9f8;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-top: 16rpx;
}

/* Skeleton Loaders */
.skeleton-features {
  background: #f6f3f2;
  padding: 24rpx;
}

.skeleton-feature-item {
  height: 36rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  width: 80%;
  background-color: var(--skeleton-color, #f0f0f0);
}
.skeleton-feature-item:last-child {
  margin-bottom: 0;
}
.skeleton-feature-item:nth-child(2) { width: 60%; }
.skeleton-feature-item:nth-child(3) { width: 90%; }

.skeleton-header-left {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex: 1;
  justify-content: center;
}
.skeleton-name {
  width: 240rpx;
  height: 56rpx;
  margin-bottom: 8rpx;
}
.skeleton-desc {
  width: 320rpx;
  height: 32rpx;
  margin-bottom: 6rpx;
}
.skeleton-desc-short {
  width: 200rpx;
  height: 32rpx;
}
.skeleton-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}
.skeleton-tag {
  height: 48rpx;
  background-color: var(--skeleton-color, #f0f0f0);
  border-radius: 24rpx;
  background-image: var(--skeleton-gradient, linear-gradient(90deg, #f0f0f0 25%, #e2e2e2 37%, #f0f0f0 63%));
  background-size: 400% 100%;
  animation: skeleton-loading 1.4s ease infinite;
}

.ingredient-thumb-wrap {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
  background-color: var(--skeleton-color, #f0f0f0);
}
.scan-line {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4rpx;
  background: rgba(75, 99, 56, 0.8);
  box-shadow: 0 0 10rpx rgba(75, 99, 56, 0.8);
  animation: scan 2s linear infinite;
  z-index: 2;
}
@keyframes scan {
  0% { transform: translateY(-100%); }
  100% { transform: translateY(140rpx); }
}

.skeleton-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 30rpx !important;
}
.skeleton-icon {
  width: 36rpx;
  height: 36rpx;
  background-color: var(--skeleton-color, #f0f0f0);
  border-radius: 50%;
  margin-right: 12rpx;
  background-image: var(--skeleton-gradient, linear-gradient(90deg, #f0f0f0 25%, #e2e2e2 37%, #f0f0f0 63%));
  background-size: 400% 100%;
  animation: skeleton-loading 1.4s ease infinite;
}
.skeleton-title {
  width: 200rpx;
  height: 36rpx;
}
.skeleton-clue-box {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  gap: 24rpx;
  align-items: center;
}
.skeleton-clue-left {
  flex-shrink: 0;
}
.skeleton-icon-large {
  width: 80rpx;
  height: 80rpx;
  background-color: var(--skeleton-color, #f0f0f0);
  border-radius: 50%;
  background-image: var(--skeleton-gradient, linear-gradient(90deg, #f0f0f0 25%, #e2e2e2 37%, #f0f0f0 63%));
  background-size: 400% 100%;
  animation: skeleton-loading 1.4s ease infinite;
}
.skeleton-clue-right {
  flex: 1;
}

.skeleton-card {
  height: 240rpx;
  background: #ffffff;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
  padding: 24rpx;
  box-sizing: border-box;
}
.skeleton-recipe-icon-box {
  width: 70rpx;
  height: 70rpx;
  border-radius: 16rpx;
  background-color: var(--skeleton-color, #f0f0f0);
  background-image: var(--skeleton-gradient, linear-gradient(90deg, #f0f0f0 25%, #e2e2e2 37%, #f0f0f0 63%));
  background-size: 400% 100%;
  animation: skeleton-loading 1.4s ease infinite;
}

.skeleton-header {
  margin-bottom: 24rpx;
}

.loading-pulse-text {
  color: #4b6338;
  font-weight: 600;
  transition: opacity 0.5s ease;
  animation: pulse-text 2s infinite ease-in-out;
}

@keyframes pulse-text {
  0% { opacity: 0.7; transform: scale(0.99); }
  50% { opacity: 1; transform: scale(1); }
  100% { opacity: 0.7; transform: scale(0.99); }
}

.feature-item {
  display: flex;
  align-items: flex-start;
  font-size: 28rpx;
  line-height: 1.5;
}

.feature-label {
  color: #74796d;
  flex-shrink: 0;
  width: 140rpx;
  font-weight: 500;
}

.feature-value {
  color: #1b1c1c;
  flex: 1;
  word-wrap: break-word;
  word-break: break-word;
}

/* Analysis Section */
.analysis-section {
  background: #f6f3f2;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 30rpx 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.icon-eco, .icon-recipe {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1b1c1c;
  flex: 1;
}

.freshness-badge {
  padding: 8rpx 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.freshness-fresh {
  background: #4b6338;
  color: white;
}

.freshness-normal {
  background: #ff9800;
  color: white;
}

.freshness-bad {
  background: #ba1a1a;
  color: white;
}

.freshness-clue {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.clue-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(75, 99, 56, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-clue {
  width: 40rpx;
  height: 40rpx;
}

.clue-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.clue-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1b1c1c;
}

.clue-desc {
  font-size: 24rpx;
  color: #44483e;
}

.icon-check {
  width: 40rpx;
  height: 40rpx;
}

/* Recipes Section */
.recipes-section {
  padding: 0 30rpx 40rpx;
}

.recipe-tabs {
  display: flex;
  margin-bottom: 30rpx;
  background: #f6f3f2;
  border-radius: 20rpx;
  padding: 8rpx;
}

.recipe-tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #74796d;
  padding: 16rpx 0;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.3s ease;
}

.recipe-tab.active {
  color: #1b1c1c;
  font-weight: bold;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.recipe-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.recipe-card {
  background: #ffffff;
  border: 2rpx solid transparent;
  border-radius: 24rpx;
  padding: 24rpx;
  position: relative;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.recipe-card.selected {
  border-color: #4b6338;
  background: rgba(75, 99, 56, 0.02);
}

.recipe-card-icon-wrapper {
  width: 70rpx;
  height: 70rpx;
  border-radius: 16rpx;
  background: #f6f3f2;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.recipe-card.selected .recipe-card-icon-wrapper {
  background: rgba(75, 99, 56, 0.05);
}

.recipe-card-icon {
  width: 40rpx;
  height: 40rpx;
}

.recipe-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1b1c1c;
  display: block;
  margin-bottom: 8rpx;
  text-transform: capitalize;
}

.recipe-ingredients {
  font-size: 22rpx;
  color: #44483e;
  display: block;
  line-height: 1.4;
}

.recipe-selected-icon {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 36rpx;
  height: 36rpx;
}

/* Action Bar */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(24px);
  padding: 32rpx 40rpx;
  padding-bottom: calc(72rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(72rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
  z-index: 100;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.btn-primary {
  flex: 2;
  height: 100rpx;
  background: linear-gradient(to right, #4b6338, #637c4e);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(75, 99, 56, 0.15);
  padding: 0;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.btn-icon-center {
  width: 44rpx;
  height: 44rpx;
}

.btn-icon-only {
  flex: 0.5;
  padding: 0;
}

.btn-secondary {
  flex: 1;
  height: 100rpx;
  background: #f6f3f2;
  color: #4b6338;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary.btn-icon-only image {
  filter: brightness(0) saturate(100%) invert(35%) sepia(21%) saturate(756%) hue-rotate(50deg) brightness(97%) contrast(85%); /* #4b6338 */
}

.btn-primary::after, .btn-secondary::after {
  border: none;
}

/* States */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.error-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
}

.error-state text {
  font-size: 30rpx;
  color: #44483e;
  margin-bottom: 40rpx;
}

.incomplete-state {
  padding: 60rpx 40rpx;
  text-align: center;
}

.incomplete-tips {
  font-size: 30rpx;
  color: #ba1a1a;
  display: block;
  margin-bottom: 40rpx;
}

.disclaimer {
  padding: 0 40rpx 40rpx;
}

.disclaimer text {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
  display: block;
}
/* Tutorial Bottom Sheet */
.tutorial-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.tutorial-mask.show {
  opacity: 1;
  visibility: visible;
}

.tutorial-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #f6f3f2; /* 整个底色改为微灰，凸显白色的卡片 */
  border-radius: 40rpx 40rpx 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 85vh; /* 高度调高一点，能容纳更多内容 */
  display: flex;
  flex-direction: column;
}

.tutorial-sheet.show {
  transform: translateY(0);
}

.tutorial-header {
  padding: 40rpx 40rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  background: #ffffff; /* 头部保持纯白 */
  border-radius: 40rpx 40rpx 0 0;
  z-index: 2;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
}

.tutorial-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1b1c1c;
}

.tutorial-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #74796d;
  background: #fcf9f8;
  border-radius: 30rpx;
}

.tutorial-content {
  flex: 1;
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
  position: relative;
}

.tutorial-loading, .tutorial-error, .tutorial-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  flex: 1;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #fb7299; /* 加载圈用B站粉色 */
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text, .error-text {
  font-size: 28rpx;
  color: #74796d;
}

.tutorial-list {
  padding: 30rpx 30rpx 40rpx;
  height: 60vh; /* Set explicit height to make scroll-view scrollable */
  box-sizing: border-box;
}

.tutorial-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #ffffff; /* 卡片纯白 */
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04); /* 增加投影层级感 */
  transition: all 0.2s ease;
}

.tutorial-card:active {
  background: #fafafa;
  transform: scale(0.98);
}

.tutorial-thumb {
  width: 240rpx; /* 缩略图大一点点 */
  height: 150rpx;
  border-radius: 16rpx;
  background: #e0e0e0;
  flex-shrink: 0;
  object-fit: cover;
}

.tutorial-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.tutorial-video-title {
  font-size: 28rpx;
  color: #1b1c1c;
  font-weight: 600;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tutorial-platform {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.platform-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  flex: 1;
}

.view-count {
  font-size: 20rpx;
  color: #74796d;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.platform-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.platform-tag.bilibili {
  background: #fb7299;
  color: #ffffff;
}

.tutorial-link-text {
  font-size: 24rpx;
  color: #1b1c1c;
  font-weight: bold;
  background: #f6f3f2;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.container {
  padding: 30rpx;
}

.list-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  margin-bottom: 40rpx;
}

.header {
  margin-bottom: 40rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx dashed rgba(196, 200, 187, 0.3);
}

.title-group {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  color: #1b1c1c;
  line-height: 1.2;
  margin-bottom: 12rpx;
  letter-spacing: -0.5px;
  word-break: break-word;
  text-transform: capitalize;
}

.recipe-badge-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  gap: 16rpx;
  flex-wrap: nowrap; /* 强制在一行 */
}

.recipe-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(75, 99, 56, 0.1);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  flex-shrink: 1;
  overflow: hidden;
}

.btn-tutorial-small {
  font-size: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #fb7299, #ff85a8);
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-weight: bold;
  display: inline-flex;
  align-items: center;
  transition: all 0.2s;
  flex-shrink: 0; /* 保证按钮不被挤压 */
  box-shadow: 0 6rpx 16rpx rgba(251, 114, 153, 0.3);
}

.btn-tutorial-small:active {
  background: linear-gradient(135deg, #e06085, #f57497);
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(251, 114, 153, 0.2);
}

.icon-restaurant {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

.recipe-badge text {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #4b6338;
  font-weight: 600;
  font-size: 22rpx;
  text-transform: capitalize;
}

.subtitle-group {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 20rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #74796d;
  flex: 1;
  word-break: break-word;
}

.hint-text {
  font-size: 24rpx;
  color: #a3a69d;
  flex-shrink: 0;
}

.ingredient-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.ingredient-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  border: 2rpx solid rgba(196, 200, 187, 0.2);
  transition: all 0.2s ease;
}

.item-content {
  display: flex;
  align-items: center;
}

.ingredient-item.checked {
  background: rgba(75, 99, 56, 0.02);
  border-color: rgba(75, 99, 56, 0.2);
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #c4c8bb;
  border-radius: 12rpx;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.checkbox-checked {
  background: #4b6338;
  border-color: #4b6338;
}

.check-icon {
  width: 24rpx;
  height: 24rpx;
}

.ingredient-name {
  font-size: 32rpx;
  color: #1b1c1c;
  font-weight: 500;
  transition: all 0.2s ease;
  text-transform: capitalize;
}

.ingredient-item.checked .ingredient-name {
  color: #74796d;
  text-decoration: line-through;
}

/* Action Bar */
.bottom-action-area {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: linear-gradient(to top, #fcf9f8 85%, rgba(252, 249, 248, 0));
  padding-top: 60rpx;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-bar {
  width: 100%;
  padding: 0 40rpx;
  display: flex;
  gap: 20rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.btn-primary {
  flex: 1.5;
  height: 100rpx;
  background: linear-gradient(to right, #4b6338, #637c4e);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(75, 99, 56, 0.15);
  padding: 0;
  white-space: nowrap;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.btn-icon-center {
  width: 44rpx;
  height: 44rpx;
}

.btn-icon-only {
  flex: 0.5;
  padding: 0;
}

.btn-secondary {
  flex: 1;
  height: 100rpx;
  background: #ffffff;
  color: #4b6338;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  padding: 0;
  white-space: nowrap;
}

.btn-primary::after, .btn-secondary::after {
  border: none;
}

.clear-data-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  padding-bottom: 20rpx;
}

.clear-btn {
  background: transparent;
  color: #a3a69d;
  font-size: 24rpx;
  padding: 10rpx 30rpx;
}

.clear-btn::after {
  border: none;
}

/* Custom Success Modal */
.custom-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.custom-modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.custom-modal-dialog {
  width: 620rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  transform: scale(0.9);
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
}

.custom-modal-dialog.show {
  transform: scale(1);
}

.custom-modal-content {
  padding: 48rpx 40rpx;
  text-align: center;
}

.custom-modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1b1c1c;
  margin-bottom: 24rpx;
}

.custom-modal-desc {
  font-size: 30rpx;
  color: #74796d;
  line-height: 1.5;
}

.custom-modal-footer {
  display: flex;
  flex-direction: row;
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
}

.custom-modal-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #1b1c1c;
  border-right: 1rpx solid rgba(0, 0, 0, 0.1);
  background: #ffffff;
  transition: background 0.2s;
}

.custom-modal-btn:last-child {
  border-right: none;
}

.custom-modal-btn:active {
  background: #f6f3f2;
}

.custom-modal-btn.btn-primary-text {
  color: #4b6338;
  font-weight: bold;
}

.edit-name-input {
  width: 100%;
  height: 88rpx;
  background: #f6f3f2;
  border-radius: 16rpx;
  margin-top: 32rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #1b1c1c;
  text-align: left;
  box-sizing: border-box;
}