<view class="container">
  <view wx:if="{{result}}" class="result-card">
    <view class="ingredient-info">
      <view class="ingredient-header-wrap">
        <view class="ingredient-header-left" wx:if="{{!loadingVision}}">
          <text class="ingredient-name">{{result.ingredientName}}</text>
          <text class="ingredient-desc">{{result.ingredientDesc}}</text>
        </view>
        <view class="ingredient-header-left skeleton-header-left" wx:else>
          <view class="skeleton-text skeleton-name"></view>
          <view class="skeleton-text skeleton-desc"></view>
          <view class="skeleton-text skeleton-desc-short"></view>
        </view>
        <view class="ingredient-thumb-wrap">
          <image class="ingredient-thumb" wx:if="{{result.imagePath}}" src="{{result.imagePath}}" mode="aspectFill" bindtap="previewImage"></image>
          <view class="scan-line" wx:if="{{loadingVision}}"></view>
        </view>
      </view>
      
      <view class="ingredient-features skeleton-features" wx:if="{{loadingVision}}">
        <view class="skeleton-text skeleton-feature-item"></view>
        <view class="skeleton-text skeleton-feature-item"></view>
        <view class="skeleton-text skeleton-feature-item"></view>
      </view>
      <view class="ingredient-features" wx:if="{{!loadingVision && (result.taste || result.texture || result.similar)}}">
        <view class="feature-item" wx:if="{{result.taste}}">
          <text class="feature-label">{{i18n.res_taste}}</text>
          <text class="feature-value">{{result.taste}}</text>
        </view>
        <view class="feature-item" wx:if="{{result.texture}}">
          <text class="feature-label">{{i18n.res_texture}}</text>
          <text class="feature-value">{{result.texture}}</text>
        </view>
        <view class="feature-item" wx:if="{{result.similar}}">
          <text class="feature-label">{{i18n.res_similar}}</text>
          <text class="feature-value">{{result.similar}}</text>
        </view>
      </view>
    </view>

    <view class="analysis-section" wx:if="{{!loadingVision}}">
      <view class="section-header">
        <image class="icon-eco" src="/images/icons/eco.svg" mode="aspectFit"></image>
        <text class="section-title">{{i18n.res_freshness_title}}</text>
        <view class="freshness-badge freshness-{{result.freshnessClass}}">
          {{result.freshnessLevel}}
        </view>
      </view>
      
      <view class="freshness-clue">
        <view class="clue-icon-wrapper">
          <image class="icon-clue" src="/images/icons/beaker.svg" mode="aspectFit"></image>
        </view>
        <view class="clue-text">
          <text class="clue-title">{{i18n.res_clue_title}}</text>
          <text class="clue-desc">{{result.freshnessReason}}</text>
        </view>
        <image class="icon-check" src="/images/icons/check_circle.svg" mode="aspectFit"></image>
      </view>
    </view>
    
    <view class="analysis-section skeleton-section" wx:else>
      <view class="section-header">
        <view class="skeleton-icon"></view>
        <view class="skeleton-text skeleton-title"></view>
      </view>
      <view class="skeleton-clue-box">
        <view class="skeleton-clue-left">
          <view class="skeleton-icon-large"></view>
        </view>
        <view class="skeleton-clue-right">
          <view class="skeleton-text" style="width: 40%; height: 28rpx; margin-bottom: 16rpx;"></view>
          <view class="skeleton-text" style="width: 100%; height: 24rpx; margin-bottom: 12rpx;"></view>
          <view class="skeleton-text" style="width: 80%; height: 24rpx; margin-bottom: 12rpx;"></view>
          <view class="skeleton-text" style="width: 60%; height: 24rpx;"></view>
        </view>
      </view>
    </view>

    <view class="recipes-section" wx:if="{{loadingVision || (displayRecipes && displayRecipes.length > 0) || loadingFamiliar || loadingLocal}}">
      <view class="section-header" wx:if="{{!showTabs && !loadingVision && !loadingFamiliar && (!loadingLocal || activeTab === 'familiar')}}">
        <image class="icon-recipe" src="/images/icons/restaurant_menu.svg" mode="aspectFit"></image>
        <text class="section-title">{{i18n.res_recipes_title}}</text>
      </view>
      
      <view class="section-header skeleton-header" wx:if="{{loadingVision || loadingFamiliar}}">
        <image class="icon-recipe" src="/images/icons/restaurant_menu.svg" mode="aspectFit"></image>
        <text class="section-title loading-pulse-text">{{loadingVision ? loadingText : i18n.loading_familiar}}</text>
      </view>

      <view class="recipe-tabs" wx:if="{{showTabs || (!loadingFamiliar && loadingLocal)}}">
        <view class="recipe-tab {{activeTab === 'familiar' ? 'active' : ''}}" bindtap="switchTab" data-tab="familiar">
          <text>{{i18n.tab_familiar_recipe}}</text>
        </view>
        <view class="recipe-tab {{activeTab === 'local' ? 'active' : ''}}" bindtap="switchTab" data-tab="local">
          <text wx:if="{{!loadingLocal}}">{{i18n.tab_local_recipe}}</text>
          <text wx:else class="loading-pulse">{{i18n.loading_local}}</text>
        </view>
      </view>

      <view class="recipe-grid" wx:if="{{displayRecipes && displayRecipes.length > 0 && !(loadingLocal && activeTab === 'local')}}">
        <view 
          wx:for="{{displayRecipes}}" 
          wx:key="index"
          class="recipe-card {{selectedIndex === index ? 'selected' : ''}}"
          bindtap="selectRecipe"
          data-index="{{index}}">
          <view class="recipe-card-icon-wrapper">
            <image class="recipe-card-icon" src="/images/icons/cooking-{{index % 3 + 1}}.svg" mode="aspectFit"></image>
          </view>
          <text class="recipe-name">{{item.recipeName}}</text>
          <text class="recipe-ingredients" wx:if="{{item.ingredients_summary}}">{{item.ingredients_summary}}</text>
          <image wx:if="{{selectedIndex === index}}" class="recipe-selected-icon" src="/images/icons/check_circle.svg" mode="aspectFit"></image>
        </view>
      </view>
      
      <view class="recipe-grid skeleton-grid" wx:elif="{{ loadingVision || loadingFamiliar || (loadingLocal && activeTab === 'local') }}">
        <view class="recipe-card skeleton-card">
          <view class="skeleton-recipe-icon-box"></view>
          <view class="skeleton-text" style="width: 70%; height: 32rpx; margin-top: 24rpx; border-radius: 8rpx;"></view>
          <view class="skeleton-text" style="width: 100%; height: 24rpx; margin-top: 16rpx; border-radius: 8rpx;"></view>
          <view class="skeleton-text" style="width: 50%; height: 24rpx; margin-top: 8rpx; border-radius: 8rpx;"></view>
        </view>
        <view class="recipe-card skeleton-card">
          <view class="skeleton-recipe-icon-box"></view>
          <view class="skeleton-text" style="width: 80%; height: 32rpx; margin-top: 24rpx; border-radius: 8rpx;"></view>
          <view class="skeleton-text" style="width: 90%; height: 24rpx; margin-top: 16rpx; border-radius: 8rpx;"></view>
          <view class="skeleton-text" style="width: 40%; height: 24rpx; margin-top: 8rpx; border-radius: 8rpx;"></view>
        </view>
      </view>
    </view>

    <view class="action-bar" wx:if="{{displayRecipes && displayRecipes.length > 0 && !loadingFamiliar}}">
      <view class="action-buttons" style="display:flex; width: 100%; gap: 16rpx;">
        <button class="btn-secondary btn-icon-only" bindtap="retry" style="flex: 0 0 96rpx;">
          <image class="btn-icon-center" src="/images/icons/retry.svg" mode="aspectFit"></image>
        </button>
        <button class="btn-secondary btn-icon-only" bindtap="toggleFavorite" style="flex: 0 0 96rpx;">
          <image class="btn-icon-center" src="/images/icons/{{isFavorited ? 'favorite_filled' : 'favorite'}}.svg" mode="aspectFit"></image>
        </button>
        <button class="btn-secondary btn-icon-only" bindtap="generateList" style="flex: 0 0 96rpx;">
          <image class="btn-icon-center" src="/images/icons/shopping_cart.svg" mode="aspectFit"></image>
        </button>
        <button class="btn-secondary btn-icon-only" open-type="share" style="flex: 0 0 96rpx;">
          <image class="btn-icon-center" src="/images/icons/share.svg" mode="aspectFit"></image>
        </button>
        <button class="btn-primary" bindtap="viewRecipe" style="flex: 1; padding: 0 10rpx; font-size: 28rpx;">
          <view class="btn-content" style="justify-content: center;">
            <text class="sys-icon icon-menu_book"></text>
            <text style="margin-left: 8rpx;">{{i18n.res_view_recipe}}</text>
          </view>
        </button>
      </view>
    </view>

    <view class="disclaimer" wx:if="{{displayRecipes && displayRecipes.length > 0 && !loadingFamiliar}}">
      <text>{{i18n.res_disclaimer}}</text>
    </view>

    <view class="incomplete-state" wx:elif="{{!loadingVision && !loadingFamiliar && !loadingLocal}}">
      <text class="incomplete-tips">{{i18n.res_incomplete}}</text>
      <view class="action-bar">
        <view class="action-buttons">
          <button class="btn-primary" bindtap="retry">{{i18n.res_retake}}</button>
          <button class="btn-secondary" bindtap="goHome">{{i18n.res_back_home}}</button>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="error-state">
    <image class="error-icon" src="/images/icons/error.svg" mode="aspectFit"></image>
    <text>{{i18n.res_load_failed}}</text>
    <button class="btn-primary" bindtap="goHome">{{i18n.res_back_home}}</button>
  </view>

  <!-- Custom Success Modal -->
  <view class="custom-modal-mask {{showSuccessModal ? 'show' : ''}}" catchtouchmove="preventTouchMove">
    <view class="custom-modal-dialog {{showSuccessModal ? 'show' : ''}}">
      <view class="custom-modal-content">
        <view class="custom-modal-title">{{i18n.res_modal_title}}</view>
        <view class="custom-modal-desc">{{i18n.res_modal_desc}}</view>
      </view>
      <view class="custom-modal-footer">
        <view class="custom-modal-btn" bindtap="modalClose">{{i18n.res_modal_back}}</view>
        <view class="custom-modal-btn" bindtap="modalContinue">{{i18n.res_modal_continue}}</view>
        <view class="custom-modal-btn btn-primary-text" bindtap="modalViewList">{{i18n.res_modal_view_list}}</view>
      </view>
    </view>
  </view>
</view>