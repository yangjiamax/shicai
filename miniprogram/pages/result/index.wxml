<view class="container">
  <view wx:if="{{result}}" class="result-card">
    <view class="ingredient-info">
      <view class="ingredient-header-wrap">
        <view class="ingredient-header-left">
          <text class="ingredient-name">{{result.ingredient_name}}</text>
          <text class="ingredient-desc">{{result.ingredient_desc}}</text>
        </view>
        <image class="ingredient-thumb" wx:if="{{result.imagePath}}" src="{{result.imagePath}}" mode="aspectFill" bindtap="previewImage"></image>
      </view>
      
      <view class="ingredient-features" wx:if="{{result.taste || result.texture || result.similar}}">
        <view class="feature-item" wx:if="{{result.taste}}">
          <text class="feature-label">{{i18n.res_taste}}</text>
          <text class="feature-value">{{result.taste}}</text>
        </view>
        <view class="feature-item" wx:if="{{result.texture}}">
          <text class="feature-label">{{i18n.res_texture}}</text>
          <text class="feature-value">{{result.texture}}</text>
        </view>
        <view class="feature-item" wx:if="{{result.similar}}">
          <text class="feature-label">{{i18n.res_similar}}</text>
          <text class="feature-value">{{result.similar}}</text>
        </view>
      </view>
    </view>

    <view class="analysis-section">
      <view class="section-header">
        <image class="icon-eco" src="/images/icons/eco.svg" mode="aspectFit"></image>
        <text class="section-title">{{i18n.res_freshness_title}}</text>
        <view class="freshness-badge freshness-{{result.freshness_class}}">
          {{result.freshness_level}}
        </view>
      </view>
      
      <view class="freshness-clue">
        <view class="clue-icon-wrapper">
          <image class="icon-clue" src="/images/icons/beaker.svg" mode="aspectFit"></image>
        </view>
        <view class="clue-text">
          <text class="clue-title">{{i18n.res_clue_title}}</text>
          <text class="clue-desc">{{result.freshness_reason}}</text>
        </view>
        <image class="icon-check" src="/images/icons/check_circle.svg" mode="aspectFit"></image>
      </view>
    </view>

    <view class="recipes-section" wx:if="{{(displayRecipes && displayRecipes.length > 0) || loadingFamiliar || loadingLocal}}">
      <view class="section-header" wx:if="{{!showTabs && !loadingFamiliar && (!loadingLocal || activeTab === 'familiar')}}">
        <image class="icon-recipe" src="/images/icons/restaurant_menu.svg" mode="aspectFit"></image>
        <text class="section-title">{{i18n.res_recipes_title}}</text>
      </view>
      
      <view class="section-header skeleton-header" wx:if="{{loadingFamiliar}}">
        <image class="icon-recipe" src="/images/icons/restaurant_menu.svg" mode="aspectFit"></image>
        <text class="section-title loading-pulse">{{i18n.loading_familiar}}</text>
      </view>

      <view class="recipe-tabs" wx:if="{{showTabs || (!loadingFamiliar && loadingLocal)}}">
        <view class="recipe-tab {{activeTab === 'familiar' ? 'active' : ''}}" bindtap="switchTab" data-tab="familiar">
          <text>{{i18n.tab_familiar_recipe}}</text>
        </view>
        <view class="recipe-tab {{activeTab === 'local' ? 'active' : ''}}" bindtap="switchTab" data-tab="local">
          <text wx:if="{{!loadingLocal}}">{{i18n.tab_local_recipe}}</text>
          <text wx:else class="loading-pulse">{{i18n.loading_local}}</text>
        </view>
      </view>

      <view class="recipe-grid" wx:if="{{displayRecipes && displayRecipes.length > 0 && !(loadingLocal && activeTab === 'local')}}">
        <view 
          wx:for="{{displayRecipes}}" 
          wx:key="index"
          class="recipe-card {{selectedIndex === index ? 'selected' : ''}}"
          bindtap="selectRecipe"
          data-index="{{index}}">
          <view class="recipe-card-icon-wrapper">
            <image class="recipe-card-icon" src="/images/icons/cooking-{{index % 3 + 1}}.svg" mode="aspectFit"></image>
          </view>
          <text class="recipe-name">{{item.recipe_name}}</text>
          <text class="recipe-ingredients" wx:if="{{item.ingredients_summary}}">{{item.ingredients_summary}}</text>
          <image wx:if="{{selectedIndex === index}}" class="recipe-selected-icon" src="/images/icons/check_circle.svg" mode="aspectFit"></image>
        </view>
      </view>
      
      <view class="recipe-grid skeleton-grid" wx:elif="{{loadingFamiliar || (loadingLocal && activeTab === 'local')}}">
        <view class="recipe-card skeleton-card"></view>
        <view class="recipe-card skeleton-card"></view>
      </view>
    </view>

    <view class="action-bar" wx:if="{{displayRecipes && displayRecipes.length > 0 && !loadingFamiliar}}">
      <button class="btn-primary" bindtap="generateList">
        <view class="btn-content">
          <image class="btn-icon" src="/images/icons/shopping_cart.svg" mode="aspectFit"></image>
          <text>{{i18n.res_generate_list}}</text>
        </view>
      </button>
      <button class="btn-secondary btn-icon-only" bindtap="retry">
        <image class="btn-icon-center" src="/images/icons/retry.svg" mode="aspectFit"></image>
      </button>
    </view>

    <view class="disclaimer" wx:if="{{displayRecipes && displayRecipes.length > 0 && !loadingFamiliar}}">
      <text>{{i18n.res_disclaimer}}</text>
    </view>

    <view class="incomplete-state" wx:elif="{{!loadingFamiliar && !loadingLocal}}">
      <text class="incomplete-tips">{{i18n.res_incomplete}}</text>
      <view class="action-bar">
        <button class="btn-primary" bindtap="retry">{{i18n.res_retake}}</button>
        <button class="btn-secondary" bindtap="goHome">{{i18n.res_back_home}}</button>
      </view>
    </view>
  </view>

  <view wx:else class="error-state">
    <image class="error-icon" src="/images/icons/error.svg" mode="aspectFit"></image>
    <text>{{i18n.res_load_failed}}</text>
    <button class="btn-primary" bindtap="goHome">{{i18n.res_back_home}}</button>
  </view>
</view>